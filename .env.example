TZ=UTC

# Login for your local IMAP archive (Dovecot)
ARCHIVE_USER=archive
# dovecot/dovecot default config expects this to stay "password"
ARCHIVE_PASSWORD=password

# Dovecot port exposed on host
DOVECOT_IMAP_PORT=1143

# Gmail source account (Gmail API + OAuth2)
GMAIL_ADDRESS=you@gmail.com

# OAuth client credentials (Google Cloud Console)
GMAIL_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-client-secret
# Or use GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET instead

# Filled after one-time terminal OAuth init
GMAIL_OAUTH_REFRESH_TOKEN=

# Must be whitelisted in your OAuth client
GMAIL_OAUTH_REDIRECT_URI=http://localhost:53682/
GMAIL_OAUTH_SCOPE=https://www.googleapis.com/auth/gmail.readonly

# Optional Gmail API query (empty = all mail except spam/trash)
GMAIL_QUERY=

# Include spam/trash in import
GMAIL_INCLUDE_SPAM_TRASH=false

# API page size for list/history calls (1-500)
GMAIL_BATCH_SIZE=200

# Log every N processed messages
GMAIL_PROGRESS_EVERY=25

# Keep this aligned with the Dovecot mail volume mount
MAIL_ROOT=/srv/vmail

# SQLite state DB for dedupe + history checkpoint
IMPORT_STATE_DB=/srv/vmail/.gmail-import-state.sqlite

# Roundcube web UI
ROUNDCUBE_HTTP_PORT=8080
ROUNDCUBE_DES_KEY=change-this-to-24+chars
